IDD_DATABASE_SELECT DIALOGEX 0, 0, 317, 197
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Path to the user database"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    GROUPBOX        "Database 1 (Local)",IDC_STATIC_DB1,7,7,303,76
    LTEXT           "Name:    ",IDC_STATIC_BEZ1,38,29,58,8
    EDITTEXT        IDC_NAME,102,26,141,14,ES_AUTOHSCROLL
    LTEXT           "Please enter path to user database  (waxuser.mdb):",IDC_STATIC_DBINFO1,38,44,226,8
    EDITTEXT        IDC_EDIT_DBPATH,38,54,205,14,ES_AUTOHSCROLL
    PUSHBUTTON      "...",IDC_DBSEL,250,57,29,10
    GROUPBOX        "Database 2 (e.g. Server)",IDC_STATIC_DB2,7,93,303,76
    LTEXT           "Name:    ",IDC_STATIC_BEZ2,38,115,58,8
    EDITTEXT        IDC_NAME2,102,112,141,14,ES_AUTOHSCROLL
    LTEXT           "Enter a second database to enable Database switching or leave empty:",IDC_STATIC_DBINFO2,37,130,226,8
    EDITTEXT        IDC_EDIT_DBPATH2,38,139,205,14,ES_AUTOHSCROLL
    PUSHBUTTON      "...",IDC_DBSEL2,250,143,29,10
    CONTROL         "&Prompt for database selection at program startup",IDC_PROMPT,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,180,203,10
    DEFPUSHBUTTON   "OK",IDOK,260,176,50,14
END


