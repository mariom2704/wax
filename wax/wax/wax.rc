/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "&Projekt"
    BEGIN
        MENUITEM "Neue Werkaufträge bearbeiten...", ID_OPEN_NEWWA
        MENUITEM "Meine Werkaufträge...",       21061
        MENUITEM "&Werkaufträge bearbeiten...", ID_OPEN_DATABASE
        MENUITEM "Projektdatei nach PSP Element erstellen...", ID_OPEN_DATABASE_PSPELEMENT
        POPUP "&Informationen zu Aufträgen"
        BEGIN
            MENUITEM "unbearbeitete &Aufträge...",  ID_AUFTRAGSTEST
        END
        MENUITEM SEPARATOR
        MENUITEM "&Neu\tStrg+N",                ID_FILE_NEW
        MENUITEM "Ö&ffnen...\tStrg+O",          ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "Drucker&einrichtung...",      ID_FILE_PRINT_SETUP
        MENUITEM SEPARATOR
        MENUITEM "Letzte Datei",                ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "&Beenden",                    ID_APP_EXIT
    END
    POPUP "&Systemverwaltung"
    BEGIN
        MENUITEM "Parameter ... ",              IDM_PARAMETER_DIALOG
        POPUP "Datenbank"
        BEGIN
            MENUITEM "&Einstellungen...",           ID_DATABASE
            MENUITEM "&Auswählen...",               ID_DATABASE_SELECT
            MENUITEM "Info...",                     ID_DATABASE_INFO
        END
        POPUP "Admin Tools"
        BEGIN
            MENUITEM "Statistik Tabellen aktualisieren", ID_DATABASE_UPDATESTATISTIK
        END
        MENUITEM SEPARATOR
        POPUP "Spanx+ Rohreingabe"
        BEGIN
            MENUITEM "Strangrohreingabe...",        ID_SPANXANFRAGE_STRANGROHR
            MENUITEM "Verteilereingabe...",         ID_SPANXANFRAGE_VERTEILER
        END
    END
    POPUP "&Ansicht"
    BEGIN
        MENUITEM "&Symbolleiste",               ID_VIEW_TOOLBAR
        MENUITEM "S&tatusleiste",               ID_VIEW_STATUS_BAR
    END
    POPUP "&?"
    BEGIN
        MENUITEM "Inf&o über Wax+...",          ID_APP_ABOUT
        MENUITEM "&Versionsgeschichte...",      ID_VERSIONSGESCHICHTE
        MENUITEM "&Anwenderdokumentation...",   ID_DOKU
    END
END

IDR_WAXTYPE MENU 
BEGIN
    POPUP "&Projekt"
    BEGIN
        MENUITEM "&Neu\tStrg+N",                ID_FILE_NEW
        MENUITEM "Ö&ffnen...\tStrg+O",          ID_FILE_OPEN
        MENUITEM "&Schließen",                  ID_FILE_CLOSE
        MENUITEM "S&peichern\tStrg+S",          ID_FILE_SAVE
        MENUITEM "Speichern &unter...",         ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "&Drucken...\tStrg+P",         ID_FILE_PRINT
        MENUITEM "Drucker&einrichtung...",      ID_FILE_PRINT_SETUP
        MENUITEM "Auswahl als Email verschicken...", ID_FILE_SEND_MAIL
        MENUITEM SEPARATOR
        MENUITEM "Letzte Datei",                ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "&Beenden",                    ID_APP_EXIT
    END
    POPUP "&Bearbeiten"
    BEGIN
        MENUITEM "&Ausschneiden\tStrg+X",       WAXID_CUT
        MENUITEM "&Kopieren\tStrg+C",           WAXID_COPY
        MENUITEM "E&infügen\tStrg+V",           WAXID_PASTE
        MENUITEM "Löschen",                     WAXID_DELETE
        MENUITEM SEPARATOR
        MENUITEM "&Umbenennen\tF2",             WAXID_UMBENENNEN
        MENUITEM "Freigeben\tF3",               ID_FREIGABE
        MENUITEM "&Status aktualisieren\tF5",   ID_STATUS_AKTUALISIEREN
    END
    POPUP "&Ansicht"
    BEGIN
        MENUITEM "&Symbolleiste",               ID_VIEW_TOOLBAR
        MENUITEM "S&tatusleiste",               ID_VIEW_STATUS_BAR
        MENUITEM SEPARATOR
        MENUITEM "Grafikvollbild anzeigen",     ID_VIEW_GRAFIK
        MENUITEM "&Druckvorschau",              ID_DRUCKVORSCHAU
        MENUITEM "&Grafikfenster unter der Eingabe", ID_NOGRAFIK
        MENUITEM SEPARATOR
        MENUITEM "Grafik mit Viewer betrachten...", ID_VOLOVIEW
    END
    POPUP "&Fenster"
    BEGIN
        MENUITEM "Über&lappend",                ID_WINDOW_CASCADE
        MENUITEM "&Nebeneinander",              ID_WINDOW_TILE_HORZ
        MENUITEM "&Symbole anordnen",           ID_WINDOW_ARRANGE
        MENUITEM SEPARATOR
        MENUITEM "&Baumansicht anzeigen\tStrg+W", ID_SHOWEXPLORE
    END
    POPUP "&?"
    BEGIN
        MENUITEM "Inf&o über Wax+...",          ID_APP_ABOUT
        MENUITEM "&Versionsgeschichte...",      ID_VERSIONSGESCHICHTE
        MENUITEM "&Anwenderdokumentation...",   ID_DOKU
    END
END


