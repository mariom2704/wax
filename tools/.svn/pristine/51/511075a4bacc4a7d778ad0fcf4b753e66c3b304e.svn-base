CGraficStranrohrContainer::CGraficStranrohrContainer( CGraficController* pCGraficController, CGraficRohrKomponenteVector StrangRohrKomponenten )
{
	m_pCGraficController = pCGraficController;
	m_GraficStrangRohrKomponenten = StrangRohrKomponenten;
}





void CGraficStranrohrContainer::CreateGraficModell()
{
	CPointDouble TubeStartPoint;
	TubeStartPoint.X = 10;
	TubeStartPoint.Y = 101;
	SetStartPointTubeCenterLine(TubeStartPoint);
	
	//std::vector<int>::size_type sz = m_GraficStrangRohrKomponenten.size();
	//for(UINT i = 1; i < sz; i++ )
	{
		
		DrawPartTubeGraficWithArc();
		//SetStartPointCenterLine(m_PointEnde);
	}
	
}






void CGraficStranrohrContainer::DrawPartTubeGraficWithArc()
{

	
	m_GraficStrangRohrKomponenten[0].SetStartPointCenterLine(GetStartPointTubeCenterLine());
	
	double CumulatedArcBefore  = 0;
	double CumulatedArcCurrent = 0;
	UINT i = 1;
	//for(UINT i = 1; i < sz; i++ )
	{
		m_GraficStrangRohrKomponenten[i-1].SetEndPointCenterLine(CumulatedArcCurrent);
		CumulatedArcBefore = CumulatedArcCurrent;
		m_GraficStrangRohrKomponenten[i-1].SetPitch();
		
		m_GraficStrangRohrKomponenten[i].SetStartPointCenterLine(m_GraficStrangRohrKomponenten[i-1].GetEndPointCenterLine());
		m_GraficStrangRohrKomponenten[i].SetEndPointCenterLine(CumulatedArcCurrent);

	
		double DrehungGradWinkel = -NEUNZIG_GRADWINKEL;
		int j = 0;
		for(int j =0; j <=1; j++)
		{
			DrehungGradWinkel = -DrehungGradWinkel;
			m_GraficStrangRohrKomponenten[i-1].SetDrehWinkel(DrehungGradWinkel);
			m_GraficStrangRohrKomponenten[i-1].SetFirstBorderpoint(CumulatedArcBefore);
			
			m_GraficStrangRohrKomponenten[i].SetDrehWinkel(DrehungGradWinkel);
			m_GraficStrangRohrKomponenten[i].SetFirstBorderpoint(CumulatedArcCurrent);	
			m_GraficStrangRohrKomponenten[i].SetSecondBorderpoint(CumulatedArcCurrent);
			m_GraficStrangRohrKomponenten[i].SetPitch();

			double dFaktor = CUtiltyHelper::GetFaktorForConnectionPoint( m_GraficStrangRohrKomponenten[i-1].GetFirstBorderpoint(), m_GraficStrangRohrKomponenten[i-1].GetPitch(),
				CPointDouble(m_GraficStrangRohrKomponenten[i].GetsecondBorderpoint().X, m_GraficStrangRohrKomponenten[i].GetsecondBorderpoint().Y), m_GraficStrangRohrKomponenten[i].GetPitch());
	
	
			double xNullPunktConnectionPointAussenWand =  m_GraficStrangRohrKomponenten[i-1].GetFirstBorderpoint().X + dFaktor * m_GraficStrangRohrKomponenten[i-1].GetPitch().X;
			double yNullPunktConnectionPointAussenWand =  m_GraficStrangRohrKomponenten[i-1].GetFirstBorderpoint().Y + dFaktor * m_GraficStrangRohrKomponenten[i-1].GetPitch().Y;

			//	m_GraficStrangRohrKomponenten[i-1].SetConnectionPoint(NullPunktConnectionPointAussenWand);
			//m_GraficStrangRohrKomponenten[i].SetConnectionPoint(NullPunktConnectionPointAussenWand);
	
	
	
			//MittellinieI
			m_pCGraficController->ZeichneLinie(m_pCGraficController->m_GraficFileController.strSVGContent,	"rgb(255,0,0)", m_GraficStrangRohrKomponenten[i-1].getStartPointCenterLine().X, m_GraficStrangRohrKomponenten[i-1].getStartPointCenterLine().Y,
				m_GraficStrangRohrKomponenten[i-1].GetEndPointCenterLine().X,  m_GraficStrangRohrKomponenten[i-1].GetEndPointCenterLine().Y );

			CString strFarbe = "rgb(0,0,0)";
			if(j==1)
				strFarbe = "rgb(0,0,255)";
			m_pCGraficController->ZeichneLinie(m_pCGraficController->m_GraficFileController.strSVGContent, strFarbe, m_GraficStrangRohrKomponenten[i-1].GetFirstBorderpoint().X, m_GraficStrangRohrKomponenten[i-1].GetFirstBorderpoint().Y,  xNullPunktConnectionPointAussenWand, yNullPunktConnectionPointAussenWand);
	
			//MittellinieII
			m_pCGraficController->ZeichneLinie(m_pCGraficController->m_GraficFileController.strSVGContent,	"rgb(255,0,0)", m_GraficStrangRohrKomponenten[i].getStartPointCenterLine().X, m_GraficStrangRohrKomponenten[i].getStartPointCenterLine().Y, m_GraficStrangRohrKomponenten[i].GetEndPointCenterLine().X,  m_GraficStrangRohrKomponenten[i].GetEndPointCenterLine().Y );

			m_pCGraficController->ZeichneLinie(m_pCGraficController->m_GraficFileController.strSVGContent, strFarbe, m_GraficStrangRohrKomponenten[i].GetsecondBorderpoint().X, m_GraficStrangRohrKomponenten[i].GetsecondBorderpoint().Y, xNullPunktConnectionPointAussenWand, yNullPunktConnectionPointAussenWand);
		}
	}

//	m_pCGraficController->ZeichneLinie(m_pCGraficController->m_GraficFileController.strSVGContent,  getEndPointCenterLine().X,  getEndPointCenterLine().Y,  xPointEqualII,  yPointEqualII);
	
}


void CGraficStranrohrContainer::calculatePunktEndePunktForKnick(double winkel,  double x, double y, double& x2, double& y2)
{
	x2 = x + cos(winkel  *  3.14 /180) * 100;
	y2 = y + sin(winkel  *  3.14 /180) * 100;
};





