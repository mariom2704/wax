        <member name="T:RohrKonfDaten.Db.DbCombobox">
            <summary>
            Werte für die <c>ComboboxExt</c> aus der Tabelle Combobox aus der Stammdatenbank lesen. 
            </summary>
            <example>Beispiel:
            \code
            int voreinstellungOberflNrId = 1;
            List[EnComboBoxWerte] werteOberfl = new List[EnComboBoxWerte]();
            DbCombobox dbCb = new DbCombobox();
            if (!dbCb.readWerte("Oberflaeche", werteOberfl))
                return;
                
            MxLib.Dialog.ComboBoxExt comboBox = new MxLib.Dialog.ComboBoxExt();
            comboBox.load(werteOberfl, voreinstellungOberflNrId, false);
            \endcode
            </example>
        </member>
        <member name="M:RohrKonfDaten.Db.DbCombobox.#ctor">
            <summary>
            Konstruktor
            </summary>
        </member>
        <member name="M:RohrKonfDaten.Db.DbCombobox.readWerte(System.String,System.Collections.Generic.List{MxLib.Entities.EnComboBoxWerte})">
            <summary>
            Anhand der übergebenen ID die Werte aus der Tabelle Combobox lesen
            </summary>
            <param name="comboId">Zu dieser ID werden alle Werte eingelesen</param>
            <param name="werte">Liste mit den Werten</param>
            <returns>false wenn ein Fehler aufgetreten ist</returns>
        </member>
        <member name="M:RohrKonfDaten.Db.DbCombobox.readWert(System.String,System.Int32,MxLib.Entities.EnComboBoxWerte)">
            <summary>
            Wert aus der Tabelle Combobox lesen
            </summary>
            <param name="comboId">Wert der ID Spalte ComboId</param>
            <param name="id">Wert der ID Spalte idCounter</param>
            <param name="cbWert">Eingelesener Wert aus der Datenbank</param>
            <returns></returns>
        </member>
