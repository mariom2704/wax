/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOG DISCARDABLE  0, 0, 235, 55
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Info über TxtReplace"
FONT 8, "MS Sans Serif"
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,11,17,20,20
    LTEXT           "TxtReplace Version 1.0",IDC_STATIC,40,10,119,8,
                    SS_NOPREFIX
    LTEXT           "Copyright (C) 2001",IDC_STATIC,40,25,119,8
    DEFPUSHBUTTON   "OK",IDOK,178,7,50,14,WS_GROUP
END

IDD_TXTREPLACE_DIALOG DIALOGEX 0, 0, 358, 180
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "Textersetzung in Header und Sourcedateien"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "&Ersetzen",IDOK,290,84,50,14
    PUSHBUTTON      "Abbrechen",IDCANCEL,290,158,50,14
    EDITTEXT        IDC_EDIT_FIND,41,33,181,14,ES_AUTOHSCROLL
    LTEXT           "Zu suchender Text (Achtung Case Sensitive!):",
                    IDC_STATIC,42,25,172,8
    LTEXT           "Ersetzen durch:",IDC_STATIC,41,51,50,8
    EDITTEXT        IDC_EDIT_REPLACE_WITH,41,59,181,14,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDIT_PATH,51,126,169,14,ES_AUTOHSCROLL
    LTEXT           "",IDC_STATUS,16,163,255,8
    PUSHBUTTON      "...",IDC_BROWSE,230,128,35,9
    CONTROL         "&Ganze Zeile löschen",IDC_CHECK_DELETELINE,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,157,79,102,10
    GROUPBOX        "Pfad",IDC_STATIC,37,112,235,40
    GROUPBOX        "Textersetzung",IDC_STATIC,35,7,236,100
    CONTROL         "&Nur ganzes Wort",IDC_CHECK_GANZES_WORT,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,49,79,95,10
    CONTROL         "&Sicherungskopie erstellen (~<Dateiname>.bak)",
                    IDC_CHECK_BACKUP,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,
                    49,92,163,10
END


