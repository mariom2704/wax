bool CGraficRohrBemassungsRohrKomponentenVector::HasAssembeldTubes()
{
	bool bHasChilds = false;
	if(m_GraficRohrBemassungsAnbauChildKomponentenVectorVector.size() > 0)
	{
		bHasChilds = true;
	}
	return bHasChilds;
}



