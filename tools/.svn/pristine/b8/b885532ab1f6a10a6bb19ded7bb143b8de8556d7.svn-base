#include "stdafx.h"
#include "Konfiguration.h"

using namespace MxSoftwareCheck;

LCID Konfiguration::lcid;

Konfiguration::Konfiguration()
{
}

Konfiguration::~Konfiguration()
{
}


void Konfiguration::init_localfiles(string localpath)
{
	configfile = localpath + "\\softwarestand.txt";
}


void Konfiguration::init_logfile_server(string serverpath)
{
	logfile = serverpath + "\\MXSoftwareCheck_" + get_computername() + ".log";
}

string Konfiguration::get_configfile() const
{
	return configfile;
}

string Konfiguration::get_logfile() const
{
	return logfile;
}


string Konfiguration::get_computername() const
{
	DWORD len(255);
	char name[255];
	::GetComputerName(name, &len);
	return name;
}

string Konfiguration::get_username() const
{
	DWORD len(255);
	char user[255];
	memset(user, 0, 255);
	::GetUserName(user, &len);
	return user;
}


unsigned long Konfiguration::get_maxage() const
{
	 return 3*30*24*60*60;
}


bool Konfiguration::use_english()
{
	WORD lid = MAKELANGID(LANG_GERMAN, SUBLANG_DEFAULT);
	LCID lc_german = MAKELCID(lid, SORT_DEFAULT);

	return lcid != lid;
}