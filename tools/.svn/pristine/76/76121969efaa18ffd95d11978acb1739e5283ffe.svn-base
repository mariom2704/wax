DROP TABLE region

!CREATE TABLE region (id INTEGER, bezeichnung VARCHAR(255), bezeichnung_english VARCHAR(255), bezeichnung_francais VARCHAR(255), PRIMARY KEY(id)) ENGINE =InnoDB DEFAULT CHARSET=latin1

