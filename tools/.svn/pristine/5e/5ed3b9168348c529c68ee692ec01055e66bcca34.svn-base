CGraficController::CGraficController(void)
{
}



void CGraficController::GenerateDrawingOfTubes(CRohrOneAssembeldKomponenteVector StrangRohrVector)
{
		m_RohrKomponenten = StrangRohrVector;
		m_GraficRohrKomponentenContainer.clear();

		std::vector<int>::size_type sz = m_RohrKomponenten.size();
				
		for(int i =0; i< (int) sz; i++)
		{
			AddGraficChildComponent(m_RohrKomponenten[i]);
		}

		CGraficRohrContainer GraficRohrContainer;
		for(UINT i = 0; i < sz; i++ )
		{
			CGraficRohrKomponente* pGraficRohrKomponente = (*m_RohrKomponenten[i]).GetGraficRohrKomponente(this);
			GraficRohrContainer.m_GraficStrangRohrKomponenten.push_back(pGraficRohrKomponente);
		}
		
		m_GraficFileController.CreateSVGFile("D:\\work\\samples\\tools\\diverse\\SVG  Grafic\\Debug\\HTML Test\\Test.svg");
		
		GraficRohrContainer.CreateGraficModell();

		for(UINT i = 0; i < sz; i++ )
		{
			GraficRohrContainer.DrawCompnent(i);
		}
	
		
		m_GraficFileController.strSVGContent+= "</svg>";
		m_GraficFileController.WriteSVGContent();
		m_pHtmlView->Navigate("D:\\work\\samples\\tools\\diverse\\SVG  Grafic\\Debug\\HTML Test\\Test.html", NULL, NULL, NULL, NULL);
}


void CGraficController::AddGraficChildComponent(CRohrKomponente* pStrangRohrKomponente )
{
		
	CGraficRohrKomponente* pGraficRohrKomponente = pStrangRohrKomponente->GetGraficRohrKomponente(this);
	if(pStrangRohrKomponente->HasKomponenteChildren())
	{

		
		std::vector<int>::size_type sz = pStrangRohrKomponente->RohrKomponenteChildVector.size();
		for(int i =0; i< (int) sz; i++)
		{
			CRohrOneAssembeldKomponenteVector* pRohrOneAssembeldKomponenteVector = pStrangRohrKomponente->RohrKomponenteChildVector[i];
			std::vector<int>::size_type ss = pRohrOneAssembeldKomponenteVector->size();
			for(int z = 0; z < (int) ss; z++)
			{
				CRohrKomponente* pRohrOneAssembeldKomponente =  pRohrOneAssembeldKomponenteVector->at(z);
				pGraficRohrKomponente->GetChildGraficContainer()->m_GraficStrangRohrKomponenten.push_back(pRohrOneAssembeldKomponente->GetGraficRohrKomponente(this));
				AddGraficChildComponent(pRohrOneAssembeldKomponente);
			}
		}
	}
	
	
}




CGraficController::~CGraficController(void)
{
}
