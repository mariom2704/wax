/*
  a    -b
	=>
  b     a
  */

void CTestEingabe::ConstructStrnrohr(CString& strPost)
{
	strPost += "<line x1='40' y1='40' x2='40' y2='80' style='stroke:rgb(0,0,0);stroke-width:2'/>"; //links nach unten
	strPost += "<line x1=\"40\" y1=\"80\" x2=\"50\" y2=\"80\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // x von links nach rechts
	strPost += "<line x1=\"50\" y1=\"80\" x2=\"50\" y2=\"40\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // y von unten nach oben
	strPost += "<line x1=\"50\" y1=\"40\" x2=\"40\" y2=\"40\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // x von rechts nach links

	
	strPost += "<line x1=\"50\" y1=\"50\" x2=\"60\" y2=\"50\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; 
	strPost += "<line x1=\"50\" y1=\"70\" x2=\"60\" y2=\"70\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; 
	

	strPost += "<line x1='60' y1='40' x2='60' y2='80' style='stroke:rgb(0,0,0);stroke-width:2'/>"; //links nach unten
	strPost += "<line x1=\"60\" y1=\"80\" x2=\"600\" y2=\"80\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // x von links nach rechts
	strPost += "<line x1=\"600\" y1=\"80\" x2=\"600\" y2=\"40\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // y von unten nach oben
	strPost += "<line x1=\"600\" y1=\"40\" x2=\"60\" y2=\"40\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // x von rechts nach links

	strPost += "<line x1=\"600\" y1=\"50\" x2=\"610\" y2=\"50\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; 
	strPost += "<line x1=\"600\" y1=\"70\" x2=\"610\" y2=\"70\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; 

	strPost += "<line x1='610' y1='40' x2='610' y2='80' style='stroke:rgb(0,0,0);stroke-width:2'/>"; //links nach unten
	strPost += "<line x1=\"610\" y1=\"80\" x2=\"620\" y2=\"80\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // x von links nach rechts
	strPost += "<line x1=\"620\" y1=\"80\" x2=\"620\" y2=\"40\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // y von unten nach oben
	strPost += "<line x1=\"620\" y1=\"40\" x2=\"610\" y2=\"40\" style=\"stroke:rgb(0,0,0);stroke-width:2\" />"; // x von rechts nach links

}


void CTestEingabe::OnBnSecondSVG()
{
	CFile hPostFile;
	CString strFile = "D:\\work\\samples\\SplitterWindowTutorial\\Debug\\HTML Test\\TestII.svg";
	
	hPostFile.m_hFile = CreateFile( strFile, GENERIC_READ | GENERIC_WRITE , 0, NULL, CREATE_ALWAYS,	0, 	NULL );        
	
	CString strPost = "<svg xmlns=\"http://www.w3.org/2000/svg\"  viewBox=\"0 0 650 880\" version=\"1.1\"> \
	<line x1=\"0\" y1=\"2\" x2=\"650\" y2=\"2\" style=\"stroke:rgb(0,0,255);stroke-width:3\" />\
	<line x1=\"0\" y1=\"877\" x2=\"650\" y2=\"877\" style=\"stroke:rgb(0,0,255);stroke-width:3\" /></svg>";

	hPostFile.Write( strPost, strPost.GetLength() );

	hPostFile.Close();
}