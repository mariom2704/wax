{ //-100
	strPost += "<line  y1='100'  y2='40'  x1='0'  x2='100' style='stroke:rgb(0,0,0);stroke-width:2'/>"; //links nach unten
	strPost += "<line  y1='100'   x1='0'   y2='200' x2='60' style='stroke:rgb(0,0,0);stroke-width:2'/>"; //links nach unten
