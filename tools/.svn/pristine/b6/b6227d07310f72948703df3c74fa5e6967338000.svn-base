IMPLEMENT_DYNCREATE(CTestEingabe, CFormView)



CRohrOneAssembeldKomponenteVector StrangRohrVector;

CTestEingabe::CTestEingabe()
	: CFormView(CTestEingabe::IDD)
{

}




CTestEingabe::~CTestEingabe()
{
	delete m_pGraficController;
}



void CTestEingabe::DoDataExchange(CDataExchange* pDX)
{
	CFormView::DoDataExchange(pDX);
}



BEGIN_MESSAGE_MAP(CTestEingabe, CFormView)
	ON_BN_CLICKED(IDC_BUTTON1, &CTestEingabe::OnBnClickedButton1)
	ON_BN_CLICKED(IDC_BUTTON2, &CTestEingabe::OnBnClickedButton2)
	ON_BN_CLICKED(IDC_BUTTON3, &CTestEingabe::OnBnClickedButton3)
	ON_BN_CLICKED(IDC_BUTTON4, &CTestEingabe::OnBnClickedButton4)
END_MESSAGE_MAP()






void CTestEingabe::OnInitialUpdate()
{
	CFormView::OnInitialUpdate();
	CMainFrame*  pF =  (CMainFrame*)AfxGetMainWnd();
	m_pHTML = (CHtmlTestview*) pF->m_mainSplitter.GetPane(1,0);
	m_pGraficController = new CGraficController(m_pHTML);
	PostMessage(WM_COMMAND, IDC_BUTTON1);
}



void CTestEingabe::AddChildren(CRohrKomponente* pRohrKomponente, int RelativerAbstandzumNaechsten)
{
	CRohrKomponenteTeilRohr* Rohrstutzen = new CRohrKomponenteTeilRohr();
	CRohrKomponenteNut* StrangRohrnNut = new CRohrKomponenteNut();

	Rohrstutzen->SetRelativerAbstandzumNaechsten(RelativerAbstandzumNaechsten);
	Rohrstutzen->SetLaenge(80);
	Rohrstutzen->SetDn(25);
	CString mm = _T("RohrstutzenTeilRohr");
	if(RelativerAbstandzumNaechsten == 50)
	{
		mm += _T("50");
	}
	Rohrstutzen->SetName(mm);
	pRohrKomponente->AddOneassembeldRohr();
	pRohrKomponente->AddChildren(Rohrstutzen);
	
	StrangRohrnNut->SetLaenge(10);
	StrangRohrnNut->SetDn(25);
	mm = _T("RohrstutzenNut");
	if(RelativerAbstandzumNaechsten == 50)
	{
		mm += _T("50");
	}
	Rohrstutzen->SetName(mm);
	pRohrKomponente->AddChildren(StrangRohrnNut);

}



void CTestEingabe::OnBnClickedButton4()
{
	StrangRohrVector.clear();

	CRohrKomponenteTeilRohr StrangRohrI, StrangRohrII;
	CRohrKomponenteBogen  RohrKomponenteBogen;
	CRohrKomponenteNut StrangRohrnNut;
	CRohrKomponenteGlatt StrangRohrnGlatt;

	StrangRohrnNut.SetWinkel(0);
	StrangRohrnNut.SetLaenge(10);
	StrangRohrnNut.SetFirstKomponent();
	StrangRohrVector.push_back(&StrangRohrnNut);
			
   	StrangRohrI.SetWinkel( 0 );
	StrangRohrI.SetLaenge(550);
	StrangRohrVector.push_back(&StrangRohrI);
	
	RohrKomponenteBogen.SetLaenge(80);
	StrangRohrVector.push_back(&RohrKomponenteBogen);

	StrangRohrII.SetWinkel(-80);
	StrangRohrII.SetLaenge(300);
	StrangRohrVector.push_back(&StrangRohrII);
	
	StrangRohrnGlatt.SetWinkel( 0 );
	StrangRohrnGlatt.SetLaenge(1);
	StrangRohrVector.push_back(&StrangRohrnGlatt);
	
	m_pGraficController->GenerateDrawingOfTubes(StrangRohrVector);
}




void CTestEingabe::OnBnClickedButton3()
{
	StrangRohrVector.clear();

	CRohrKomponenteTeilRohr StrangRohrI, StrangRohrII;
	CRohrKomponenteBogen  RohrKomponenteBogen;
	CRohrKomponenteNut StrangRohrnNut;
	CRohrKomponenteGlatt StrangRohrnGlatt;

	StrangRohrnNut.SetWinkel(0);
	StrangRohrnNut.SetLaenge(5);
	StrangRohrnNut.SetFirstKomponent();
	StrangRohrVector.push_back(&StrangRohrnNut);
	
	StrangRohrI.SetWinkel(0);
	StrangRohrI.SetLaenge(70);
	StrangRohrVector.push_back(&StrangRohrI);
	
	RohrKomponenteBogen.SetLaenge(40);
	StrangRohrVector.push_back(&RohrKomponenteBogen);
	
	StrangRohrII.SetWinkel(40);
	StrangRohrII.SetLaenge(20);
	StrangRohrVector.push_back(&StrangRohrII);


	StrangRohrnGlatt.SetWinkel( 0 );
	StrangRohrnGlatt.SetLaenge( 0 );
	StrangRohrVector.push_back(&StrangRohrnGlatt);
	
	m_pGraficController->GenerateDrawingOfTubes(StrangRohrVector);
}


void CTestEingabe::OnBnClickedButton2()
{
	StrangRohrVector.clear();

	CRohrKomponenteTeilRohr StrangRohrI, StrangRohrII, StrangRohrIII, StrangRohrIV, StrangRohrV, StrangRohrVI;
	CRohrKomponenteBogen  RohrKomponenteBogen, RohrKomponenteBogenII, RohrKomponenteBogenIII, RohrKomponenteBogenIV;
	CRohrKomponenteNut StrangRohrnNutI, StrangRohrnNutII;
	


	StrangRohrnNutI.SetWinkel(5);
	StrangRohrnNutI.SetLaenge(10);
	StrangRohrnNutI.SetFirstKomponent();
	StrangRohrVector.push_back(&StrangRohrnNutI);
	
	
   	StrangRohrI.SetWinkel( 0 );
	StrangRohrI.SetLaenge(500);
	StrangRohrVector.push_back(&StrangRohrI);
	
	AddChildren(&StrangRohrI, 440);

	AddChildren(&StrangRohrI, 170);
	
	AddChildren(&StrangRohrI, 370);

	RohrKomponenteBogen.SetLaenge(50);
	StrangRohrVector.push_back(&RohrKomponenteBogen);
	
	StrangRohrII.SetWinkel( -40 );
	StrangRohrII.SetLaenge(100);
	StrangRohrVector.push_back(&StrangRohrII);

	
	RohrKomponenteBogenII.SetLaenge(50);
	StrangRohrVector.push_back(&RohrKomponenteBogenII);//StrangRohrVector.push_back(&StrangRohrIII);

	StrangRohrIV.SetWinkel( 40 );
	StrangRohrIV.SetLaenge(200);
	StrangRohrVector.push_back(&StrangRohrIV);

	AddChildren(&StrangRohrIV, 30);
	
	AddChildren(&StrangRohrIV, 90);

	RohrKomponenteBogenIII.SetLaenge(50);
	StrangRohrVector.push_back(&RohrKomponenteBogenIII);//StrangRohrVector.push_back(&StrangRohrIII);

	StrangRohrV.SetWinkel( 80 );
	StrangRohrV.SetLaenge(100);
	StrangRohrVector.push_back(&StrangRohrV);



	RohrKomponenteBogenIV.SetLaenge(50);
	StrangRohrVector.push_back(&RohrKomponenteBogenIV);//StrangRohrVector.push_back(&StrangRohrIII);


	StrangRohrVI.SetWinkel( -80 );
	StrangRohrVI.SetLaenge(100);
	StrangRohrVector.push_back(&StrangRohrVI);
	
	AddChildren(&StrangRohrVI, 30);

	StrangRohrnNutII.SetWinkel( 0.1 );
	StrangRohrnNutII.SetLaenge(10);
	StrangRohrVector.push_back(&StrangRohrnNutII);
	
	m_pGraficController->GenerateDrawingOfTubes(StrangRohrVector);
}



