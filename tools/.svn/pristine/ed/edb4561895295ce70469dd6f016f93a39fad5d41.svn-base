		return m_pGraficRohrKomponente;
	}
	else
	{
		return m_pGraficRohrKomponente;
	}
};



CGraficRohrKomponente* CRohrKomponenteGlatt::GetGraficRohrKomponente(CGraficController* pGraficRohrContainer)
{
	if(m_pGraficRohrKomponente == 0)
	{
		CGraficRohrKomponenteGlatt* pGraficRohrKomponente = new CGraficRohrKomponenteGlatt(pGraficRohrContainer, this);
		m_pGraficRohrKomponente = (CGraficRohrKomponente*) pGraficRohrKomponente;
		return m_pGraficRohrKomponente;
	}
	else
