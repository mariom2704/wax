/////////////////////////////////////////////////////////////////////////////
// CMainFrame message handlers


BOOL CMainFrame::OnCreateClient(LPCREATESTRUCT , CCreateContext* pContext) 
{
	//calculate client size
	CRect cr;
	GetWindowRect( &cr );
	
	// Create the main splitter with 1 row and 2 columns
	if ( !m_mainSplitter.CreateStatic( this, 2, 1 ) )
	{
		MessageBox( "Error setting up m_mainSplitter", "ERROR", MB_OK | MB_ICONERROR );
		return FALSE;
	}

	// The views for each pane must be created 
	if ( !m_mainSplitter.CreateView( 0, 0, RUNTIME_CLASS(CTestEingabe),
		CSize(cr.Width()/6, cr.Height()), pContext ) )
	{
		MessageBox( "Error setting up splitter view", "ERROR", MB_OK | MB_ICONERROR );
		return FALSE;
	}

	if ( !m_mainSplitter.CreateView( 1, 0, RUNTIME_CLASS(CHtmlTestview),
		CSize(cr.Width()/6*5, cr.Height()), pContext ) )
	{
		MessageBox( "Error setting up splitter view", "ERROR", MB_OK | MB_ICONERROR );
		return FALSE;
	}

	//change flag to show splitter created
	m_bInitSplitter = true;

	//return TRUE instead of the parent method since that would
	//not show our window
	return TRUE;
}

void CMainFrame::OnSize(UINT nType, int cx, int cy) 
{
	CFrameWnd::OnSize(nType, cx, cy);
	
	CRect cr;
	GetWindowRect(&cr);

	if (m_bInitSplitter && nType != SIZE_MINIMIZED )
	{
		m_mainSplitter.SetColumnInfo( 0, cy, 0 );
		m_mainSplitter.SetRowInfo( 0, cr.Height() / 10, 50);
		m_mainSplitter.SetRowInfo( 1, cr.Height() * 9 / 10, 50);
		
		m_mainSplitter.RecalcLayout();
	}
	
}
