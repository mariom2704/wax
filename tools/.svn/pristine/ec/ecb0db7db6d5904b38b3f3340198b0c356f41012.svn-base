using System;
using System.Collections.Generic;
using System.Text;

namespace WaxEdit.Entities
{
	public class EnAbfrageMatrix
	{
		string sqlStatement;


		List<string> spalten = new List<string>();
		List<string> anzeigeFeld = new List<string>();
		List<string> editFeld = new List<string>();

		public string SqlStatement
		{
			get { return sqlStatement; }
			set { sqlStatement = value; }
		}


		public List<string> Spalten
		{
			get { return spalten;}
		}
		public List<string> AnzeigeFeld
		{
			get { return anzeigeFeld;}
		}
		public List<string> EditFeld
		{
			get { return editFeld; }
		}
	}
}
