	return m_xNullPunktForthWandPoint; 
};





void CGraficRohrKomponente::ZeichneLinie( double x1, double y1, double x2, double y2)
{ 
	CString strTemp;
	strTemp.Format( "<line  x1='%f' y1='%f' x2='%f'  y2='%f'   style='stroke:rgb(0,0,0);stroke-width:2'/>", x1, y1, x2, y2);
	m_pGraficGraficController->m_GraficFileController.strSVGContent += strTemp;	
}


void CGraficRohrKomponente::ZeichneLinie( int stroke, double x1, double y1, double x2, double y2)
{ 
	CString strTemp;
	strTemp.Format( "<line  x1='%f' y1='%f' x2='%f'  y2='%f'   style='stroke:rgb(0,0,0);stroke-width:%i'/>", x1, y1, x2, y2, stroke );
	m_pGraficGraficController->m_GraficFileController.strSVGContent += strTemp;	
}


void CGraficRohrKomponente::ZeichneLinie( double x1, double y1, double x2, double y2, CString strFarbe )
{ 
	CString strTemp;
	strTemp.Format( "<line  x1='%f' y1='%f' x2='%f'  y2='%f'   style='stroke:%s;stroke-width:2'/>", x1, y1, x2, y2, strFarbe);
	m_pGraficGraficController->m_GraficFileController.strSVGContent += strTemp;	
}


