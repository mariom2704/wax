CCGraficRohrOneAssembeldKomponenteVector::CCGraficRohrOneAssembeldKomponenteVector()
{	
}


void CCGraficRohrOneAssembeldKomponenteVector::AddComponenteForTube(CGraficRohrKomponente* pRohrKomponente)
{
	push_back(pRohrKomponente);
}


void CCGraficRohrOneAssembeldKomponenteVector::ClearMeMySelf(CCGraficRohrOneAssembeldKomponenteVector* pGraficRohrOneAssembeldKomponenteVector )
{
	
	if(pGraficRohrOneAssembeldKomponenteVector->HasAssembeldTubes())
	{
		std::vector<int>::size_type sz = pGraficRohrOneAssembeldKomponenteVector->m_GraficBemassungsKomponentenVectorVector.size();
		for(int z = 0; z < (int)sz; z++)
		{
			CGraficRohrBemassungsRohrKomponentenVector* pGraficRohrBemassungsKomponentenVector = pGraficRohrOneAssembeldKomponenteVector->m_GraficBemassungsKomponentenVectorVector[z];
		
			if(pGraficRohrBemassungsKomponentenVector->m_GraficRohrBemassungsAnbauChildKomponentenVectorVector.size() > 0)
			{
				std::vector<int>::size_type hh = pGraficRohrOneAssembeldKomponenteVector->m_GraficBemassungsKomponentenVectorVector.size();
				for(int h = 0; h < (int)hh; h++)
				{
					CCGraficRohrOneAssembeldKomponenteVector* pGraficRohrOneAssembeldKomponenteVector = pGraficRohrBemassungsKomponentenVector->m_GraficRohrBemassungsAnbauChildKomponentenVectorVector[h];
					ClearMeMySelf( pGraficRohrOneAssembeldKomponenteVector );
				}
			}
			pGraficRohrBemassungsKomponentenVector->m_GraficRohrBemassungsAnbauChildKomponentenVectorVector.erase(pGraficRohrBemassungsKomponentenVector->m_GraficRohrBemassungsAnbauChildKomponentenVectorVector.begin(), pGraficRohrBemassungsKomponentenVector->m_GraficRohrBemassungsAnbauChildKomponentenVectorVector.end());

		}
		pGraficRohrOneAssembeldKomponenteVector->m_GraficBemassungsKomponentenVectorVector.erase(pGraficRohrOneAssembeldKomponenteVector->m_GraficBemassungsKomponentenVectorVector.begin(), pGraficRohrOneAssembeldKomponenteVector->m_GraficBemassungsKomponentenVectorVector.end());
	}
	
	//m_GraficBemassungsKomponentenVectorVector.erase(m_GraficBemassungsKomponentenVectorVector.begin(), m_GraficBemassungsKomponentenVectorVector.end());
	//m_GraficAssembeldTubeVectorVector.erase(m_GraficAssembeldTubeVectorVector.begin(), m_GraficAssembeldTubeVectorVector.end());
	pGraficRohrOneAssembeldKomponenteVector->erase(pGraficRohrOneAssembeldKomponenteVector->begin(), pGraficRohrOneAssembeldKomponenteVector->end());
	delete pGraficRohrOneAssembeldKomponenteVector;
}


bool CCGraficRohrOneAssembeldKomponenteVector::HasAssembeldTubes()
{	
	std::vector<int>::size_type sz = m_GraficBemassungsKomponentenVectorVector.size();
	bool bHasChilds = false;
	for(int z = 0; z < (int)sz; z++)
	{
		CGraficRohrBemassungsRohrKomponentenVector* pGraficRohrBemassungsKomponentenVector = m_GraficBemassungsKomponentenVectorVector[z];
		
		if(pGraficRohrBemassungsKomponentenVector->m_GraficRohrBemassungsAnbauChildKomponentenVectorVector.size() > 0)
		{
			bHasChilds = true;
			break;
		}
		
	}
	return   bHasChilds; 
}



