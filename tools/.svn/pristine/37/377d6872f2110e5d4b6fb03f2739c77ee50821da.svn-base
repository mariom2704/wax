};


class CGraficRohrKomponenteGlatt : public  CGraficRohrKomponente
{
	
	public:
		CGraficRohrKomponenteGlatt(CGraficController*, CRohrKomponente LogicRohrKomponente);
		CGraficRohrKomponenteGlatt(CGraficController*, CRohrKomponente *pLogicRohrKomponente);
		virtual void SetKomponentPointfromConectonPoint();
		virtual void DrawYourSelf();
