#pragma once


class CGraficRohrKomponente
{
protected:
	 CRohrKomponente m_LogicRohrKomponente;
	 CGraficController* m_pGraficGraficController;
	

private:

	CGraficTubeController* m_pGraficRohrChildContainer;
	
	 CPointDouble m_PointAnfangCenterLinie;
	 CPointDouble m_PointEndeCenterLinie;
	 CPointDouble m_FirstBorderPoint;
	 CPointDouble m_xNullPunktBeginAussenWandBefore, m_xNullPunktSecondAussenWandBefore;
	 CPointDouble m_xNullPunktThirdWandPoint, m_xNullPunktForthWandPoint;
	 CPointDouble m_NullPointConnectionPoint, m_NullPointConnectionPointII;
	 CPointDouble m_FirstCornerPoint, m_SecondCornerPoint, m_ThirdCornerPoint, m_FourthCornerPoint;
	 int m_DrehWinkel; 
	 
	 CPointDouble  DeltaPitch;
	 double m_CumulatedWinkelRohrZuXundYAchse;
	
	
		
protected:
	double m_KomponentenWinkel;
	

public:
	CPointDouble GetConnectionPointForAbgaenge(double RelativerAbstandzumNaechsten);
	bool HasGraficKomponenteChildren()
	{
		return  m_pGraficRohrChildContainer->m_GraficContainerForAssembeldTubes.size() > 0 ?  true : false; 
	}
	CGraficTubeController* GetChildGraficContainer(){ return m_pGraficRohrChildContainer;};
	CGraficRohrKomponente(CGraficController*, CRohrKomponente LogicRohrKomponente);
	CGraficRohrKomponente(CGraficController*, CRohrKomponente *pLogicRohrKomponente);
	

	virtual void SetGraficRohrKomponentenWinkel(CGraficRohrKomponente* GraficRohrKomponente);
	
	
	void SetStartPointCenterLine(CPointDouble StartPoint);
	void SetPitchForCenterLinie();
	CPointDouble GetPitchCenterLinie();
	CPointDouble getStartPointCenterLine();
	
	void SetFirstCornerPoint(CPointDouble FirstCornerPoint);
	CPointDouble  GetFirstCornerPoint();
	void SetSecondCornerPoint(CPointDouble FirstCornerPoint);
	CPointDouble  GetSecondCornerPoint();
	void SetThirdCornerPoint(CPointDouble ThridCornerPoint);
	CPointDouble GetThirdCornerPoint();
	void SetForthCornerPoint(CPointDouble FirstCornerPoint);
	CPointDouble  GetFourthCornerPoint();

	void SetFirstBorderpoint(double CumulatedArcBefore);
	CPointDouble GetFirstBorderpoint();
	void SetSecondBorderpoint(double CumulatedArcBefore);
	CPointDouble GetSecondBorderpoint();
	void SetThirdBorderpoint(double CumulatedArcBefore);
	CPointDouble GetThirdBorderpoint();
	void SetFourthBorderpoint(double CumulatedArcBefore);
	CPointDouble GetForthBorderpoint();
	void SetConnectionPoint(CPointDouble ConnectionPoint)
	{
		m_NullPointConnectionPoint = ConnectionPoint;
	};

	CPointDouble GetConnectionPoint()
	{
		return m_NullPointConnectionPoint;
	};

	void SetConnectionPointII(CPointDouble ConnectionPoint)
	{
		m_NullPointConnectionPointII = ConnectionPoint;
	};

	CPointDouble GetConnectionPointII()
	{
		return m_NullPointConnectionPointII;
	};
	


	CPointDouble GetEndPointCenterLine();
	double SetEndPointCenterLine(double CumulatedArc);

	double GetWinkelRohrZuXundYAchse()
	{   
		return m_CumulatedWinkelRohrZuXundYAchse;
		
	}
	
	CRohrKomponente* GetLogicalRohrKomponente(){ return &m_LogicRohrKomponente;};
	virtual void DrawYourSelf() = 0;
	void ZeichneLinie(double x1, double y1, double x2,  double y2);
	void ZeichneLinie(double x1, double y1, double x2,  double y2, CString strFarbe);
	void ZeichneLinie(int stroke, double x1, double y1, double x2, double y2);


	virtual void SetKomponentPointfromConectonPoint(){return;};
	

	~CGraficRohrKomponente(void);
};



class CGraficRohrKomponenteTeilRohr: public  CGraficRohrKomponente
{
	double m_RadiusFirstBorder;
	double m_RadiusSecondBorder;
	double m_RadiusCenterLinie;
public:
	CGraficRohrKomponenteTeilRohr(CGraficController*, CRohrKomponente LogicRohrKomponente );
	CGraficRohrKomponenteTeilRohr(CGraficController*, CRohrKomponente *pLogicRohrKomponente);
	virtual void DrawYourSelf();

};


class CGraficRohrKomponenteBogen : public  CGraficRohrKomponente
{
		double m_RadiusFirstBorder;
		double m_RadiusSecondBorder;
		double m_RadiusCenterLinie;
	public:
		CGraficRohrKomponenteBogen(CGraficController*, CRohrKomponente LogicRohrKomponente);
		CGraficRohrKomponenteBogen(CGraficController*, CRohrKomponente *pLogicRohrKomponente);
		virtual void SetKomponentPointfromConectonPoint();
		virtual void DrawYourSelf();
		virtual void SetGraficRohrKomponentenWinkel(CGraficRohrKomponente* GraficRohrKomponente);
		
	void SetGraficRohrKomponentenWinkelDirect(double Winkel)
	{
		m_KomponentenWinkel = Winkel;
	}

	double  GetGraficRohrKomponentenWinkel()
	{
		return m_KomponentenWinkel;
	}
	
	};


class CGraficRohrKomponenteNut : public  CGraficRohrKomponente
{
	private:
		CPointDouble m_RohrFirstEndPoint, m_RohrFirstEndPointI;
		CPointDouble m_RohrSecondEndPoint, m_RohrSecondEndPointI;
		CPointDouble m_RohrThridEndPoint, m_RohrThridEndPointI; 
		CPointDouble m_RohrForthEndPoint, m_RohrForthEndPointI; 
