#include "stdafx.h"
#include "SplitterWindowTutorial.h"

#include "TestEingabe.h"
#include "MainFrm.h"

#include <math.h>

#include "Tubes it self\\StrangRohr.h"

IMPLEMENT_DYNCREATE(CTestEingabe, CFormView)



CRohrKomponenteVector StrangRohrVector;

CTestEingabe::CTestEingabe()
	: CFormView(CTestEingabe::IDD)
{

}




CTestEingabe::~CTestEingabe()
{
	delete m_pGraficController;
}



void CTestEingabe::DoDataExchange(CDataExchange* pDX)
{
	CFormView::DoDataExchange(pDX);
}



BEGIN_MESSAGE_MAP(CTestEingabe, CFormView)
	ON_BN_CLICKED(IDC_BUTTON1, &CTestEingabe::OnBnClickedButton1)
END_MESSAGE_MAP()



void CTestEingabe::OnBnClickedButton1()
{
	StrangRohrVector.clear();

	CRohrKomponenteTeilRohr StrangRohrI, StrangRohrII, StrangRohrIII, StrangRohrIV;
	CRohrKomponenteBogen  RohrKomponenteBogen, RohrKomponenteBogenII;
	CRohrKomponenteNut StrangRohrnNutI, StrangRohrnNutII;
	

	StrangRohrnNutI.SetWinkel( 0 );
	StrangRohrnNutI.SetLaenge(10);
	StrangRohrnNutI.SetFirstKomponent();
	StrangRohrVector.push_back(&StrangRohrnNutI);
	
	
	//StrangRohrI.SetprevStrangRohr(&StrangRohrI);
   	StrangRohrI.SetWinkel( 0 );
	StrangRohrI.SetLaenge(100);
	StrangRohrVector.push_back(&StrangRohrI);

	//RohrKomponenteBogen.SetWinkel( 0 );
	RohrKomponenteBogen.SetLaenge(50);
	StrangRohrVector.push_back(&RohrKomponenteBogen);
	
	StrangRohrII.SetWinkel( -90 );
	StrangRohrII.SetLaenge(100);
	StrangRohrVector.push_back(&StrangRohrII);

	//RohrKomponenteBogenII.SetWinkel( 0 );	
	RohrKomponenteBogenII.SetLaenge(50);
	StrangRohrVector.push_back(&RohrKomponenteBogenII);//StrangRohrVector.push_back(&StrangRohrIII);

	StrangRohrIV.SetWinkel( 90.1 );
	StrangRohrIV.SetLaenge(400);
	StrangRohrVector.push_back(&StrangRohrIV);

	
	StrangRohrnNutII.SetWinkel( 0.1 );
	StrangRohrnNutII.SetLaenge(10);
	StrangRohrVector.push_back(&StrangRohrnNutII);
	
	m_pGraficController->GenerateDrawingOfTubes(StrangRohrVector);
}



void CTestEingabe::OnInitialUpdate()
{
	CFormView::OnInitialUpdate();
	CMainFrame*  pF =  (CMainFrame*)AfxGetMainWnd();
	m_pHTML = (CHtmlTestview*) pF->m_mainSplitter.GetPane(1,0);
	m_pGraficController = new CGraficController(m_pHTML);
	PostMessage(WM_COMMAND, IDC_BUTTON1);
}
