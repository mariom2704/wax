CGraficTubeController::CGraficTubeController(CGraficController*pGraficController) : m_pGraficController(pGraficController)
{}


CGraficTubeController::CGraficTubeController()
{}



void CGraficTubeController::CalculateDimisions()	
{
	m_pGraficController->ResetSetDimisions();
	CreateGraficModell(true);
	CGraficComponentsForOneAssembeldTube* pRohrOneAssembeldKomponente = m_GraficRohrOneAssembeldKomponenteVectorWrapper.GetGraficRohrOneAssembeldKomponenteVector();
	std::vector<int>::size_type sz = pRohrOneAssembeldKomponente->size();
	for(int t = 0; t < (int) sz; t++)
	{
		CGraficRohrKomponente* pGraficRohrKomponente  = pRohrOneAssembeldKomponente->at(t);
		pGraficRohrKomponente->SetCalculateDemisions(false);
	}
}



void CGraficTubeController::CreateGraficModell(bool bOnlyCaculateMainTube)
{
	CPointDouble TubeStartPoint;
	TubeStartPoint.X = 50;
	TubeStartPoint.Y = 800;
	SetStartPointTubeCenterLine(TubeStartPoint);

	CCGraficRohrOneAssembeldKomponenteVector* pGraficRohrOneAssembeldKomponenteVector =  m_GraficRohrOneAssembeldKomponenteVectorWrapper.GetGraficRohrOneAssembeldKomponenteVector();
	std::vector<int>::size_type sz = pGraficRohrOneAssembeldKomponenteVector->size();
	//for(int t = 0; t < (int) sz; t++)
	{
		// Das erste Element des Hauptrohres muss gesondert behandelt werden, da das erste Element um 180 gedreht werden muss
		// als gegen die allgemeine Konstruktionsrichtung
		

		CGraficRohrKomponente* pGraficRohrKomponente  = pGraficRohrOneAssembeldKomponenteVector->at(0);
		CGraficRohrKomponente* pGraficRohrKomponenteI = pGraficRohrOneAssembeldKomponenteVector->at(1);

		pGraficRohrKomponente->SetStartPointCenterLine(GetStartPointTubeCenterLine());
		double iWinkel = pGraficRohrKomponente->GetLogicalRohrKomponente()->GetWinkel();
		pGraficRohrKomponente->GetLogicalRohrKomponente()->SetWinkel(iWinkel+180);
		pGraficRohrKomponente->SetGraficRohrKomponentenWinkel(pGraficRohrKomponenteI);
		double dCumulatedDummyWinkel = 0;
		dCumulatedDummyWinkel += pGraficRohrKomponente->SetEndPointCenterLine(dCumulatedDummyWinkel);
		pGraficRohrKomponente->SetFirstBorderpoint(dCumulatedDummyWinkel);
		pGraficRohrKomponente->SetSecondBorderpoint(dCumulatedDummyWinkel);
		pGraficRohrKomponente->SetThirdBorderpoint(dCumulatedDummyWinkel);
		pGraficRohrKomponente->SetFourthBorderpoint(dCumulatedDummyWinkel);
		pGraficRohrKomponente->SetPitchForCenterLinie();
		pGraficRohrKomponenteI->SetStartPointCenterLine(pGraficRohrKomponente->getStartPointCenterLine());
		pGraficRohrKomponente->SetKomponentPointfromConectonPoint();
				
		CreateGraficOneAssembeldTubeFromComponents(pGraficRohrKomponente->GetLogicalRohrKomponente()->GetWinkel()-180,
			m_GraficRohrOneAssembeldKomponenteVectorWrapper.GetGraficRohrOneAssembeldKomponenteVector(), bOnlyCaculateMainTube);
		
		pGraficRohrKomponente->GetLogicalRohrKomponente()->SetWinkel(iWinkel);
	}
	
}




void CGraficTubeController::RecursiveIteratetingThroughComponentsForOneAssembeldTubeAndDraw( CCGraficRohrOneAssembeldKomponenteVector* pGraficRohrOneAssembeldKomponenteVector)
{
	
	std::vector<int>::size_type ii = pGraficRohrOneAssembeldKomponenteVector->size();
	//First Draw your one Komponents
	for(int i = 0; i < (int)ii; i++)
	{
		CGraficRohrKomponente* pGraficRohrKomponente = pGraficRohrOneAssembeldKomponenteVector->at(i);
		pGraficRohrKomponente->DrawYourSelf();
	}
	
	CGraficRohrBemassungsKomponentenVectorVector& GraficRohrBemassungsKomponentenVectorVector = pGraficRohrOneAssembeldKomponenteVector->GetGraficBemassungsKomponentenVectorVector();
	std::vector<int>::size_type dd = GraficRohrBemassungsKomponentenVectorVector.size();
	for(int d = 0; d < (int)dd; d++)
	{
		CGraficRohrBemassungsRohrKomponentenVector* pGraficRohrBemassungsKomponentenVector = GraficRohrBemassungsKomponentenVectorVector[d];
		
		if(pGraficRohrBemassungsKomponentenVector->HasAssembeldTubes())
		{
		
			if(pGraficRohrOneAssembeldKomponenteVector->HasAssembeldTubes())
			{	

				CGraficRohrKomponenteVectorVector& GraficContainerVectorVectorForAssembeldChildTubes = pGraficRohrBemassungsKomponentenVector->GetGraficRohrBemassungsAnbauChildKomponentenVectorVector();
				std::vector<int>::size_type ww = GraficContainerVectorVectorForAssembeldChildTubes.size();
				for(int w = 0; w < (int)ww; w++)
				{
				
				//Now delegate DrawProcess to the Child Tubes
				CCGraficRohrOneAssembeldKomponenteVector* pRohrOneAssembeldChildTubeVector = GraficContainerVectorVectorForAssembeldChildTubes[w];
				//sz = GraficContainerForAssembeldTubes.size();
				//(/for(int i = 0; i < (int)sz; i++)
				{
					//	CCGraficRohrOneAssembeldKomponenteVector* pGraficRohrOneAssembeldChildKomponenteVector = GraficContainerForAssembeldTubes[i];
						RecursiveIteratetingThroughComponentsForOneAssembeldTubeAndDraw(pRohrOneAssembeldChildTubeVector);
				}
				
				}
			}
		}
	}
}





void CGraficTubeController::CreateGraficOneAssembeldTubeFromComponents(double CumulatedArcCurrent,  CCGraficRohrOneAssembeldKomponenteVector* pGraficParentRohrOneAssembelVector, bool bOnlyCaculateMainTube)
{
	
	
		std::vector<int>::size_type ii =  pGraficParentRohrOneAssembelVector->size();
	
		for(int i = 2; i < (int)ii+2; i=i+3)
		{
			CGraficRohrKomponente* pRohrKomponenteMII = NULL, *pRohrKomponenteMI = NULL, *pRohrKomponente = NULL, *pRohrKomponentePI = NULL, *pRohrKomponentePII = NULL;

			
			if( i < (int) ii-2)
			{
				pRohrKomponenteMII = pGraficParentRohrOneAssembelVector->at(i-2);
			}
			if( i < (int)ii-1)
			{
				pRohrKomponenteMII = pGraficParentRohrOneAssembelVector->at(i-2);
				pRohrKomponenteMI  = pGraficParentRohrOneAssembelVector->at(i-1);
			}
			if( i < (int)ii)
			{
				pRohrKomponenteMII = pGraficParentRohrOneAssembelVector->at(i-2);
				pRohrKomponenteMI  = pGraficParentRohrOneAssembelVector->at(i-1);
				pRohrKomponente	   = pGraficParentRohrOneAssembelVector->at(i);
			}
			if( i + 1 < (int)ii)
			{
				pRohrKomponenteMII = pGraficParentRohrOneAssembelVector->at(i-2);
				pRohrKomponenteMI  = pGraficParentRohrOneAssembelVector->at(i-1);
				pRohrKomponente	   = pGraficParentRohrOneAssembelVector->at(i);
				pRohrKomponentePI  = pGraficParentRohrOneAssembelVector->at(i+1);
			}
			if( i + 2 < (int)ii)
			{
				pRohrKomponenteMII = pGraficParentRohrOneAssembelVector->at(i-2);
				pRohrKomponenteMI  = pGraficParentRohrOneAssembelVector->at(i-1);
				pRohrKomponente	   = pGraficParentRohrOneAssembelVector->at(i);
				pRohrKomponentePI  = pGraficParentRohrOneAssembelVector->at(i+1);
				pRohrKomponentePII = pGraficParentRohrOneAssembelVector->at(i+2);
			}


			//Erste Kompnente
			if(i < (int) ii)
			{
				pRohrKomponenteMI->SetGraficRohrKomponentenWinkel(pRohrKomponente);
			}
			else
			{ 
				break;
			}
			CumulatedArcCurrent += pRohrKomponenteMI->SetEndPointCenterLine(CumulatedArcCurrent);
			pRohrKomponenteMI->SetFirstBorderpoint(CumulatedArcCurrent);
			pRohrKomponenteMI->SetSecondBorderpoint(CumulatedArcCurrent);
			pRohrKomponenteMI->SetThirdBorderpoint(CumulatedArcCurrent);
			pRohrKomponenteMI->SetFourthBorderpoint(CumulatedArcCurrent);
			pRohrKomponenteMI->SetPitchForCenterLinie();
			if(i < (int) ii)
			{
				;
			}
			else
			{ 
				break;
			}
		
			if(i > 2)
			{
				//Connection Point 1-2 Kompnente erste Aussenwand
				double dFaktorZeroI = CUtiltyHelper::GetFaktorForConnectionPoint( pRohrKomponenteMII->GetFirstBorderpoint(), pRohrKomponenteMII->GetPitchCenterLinie(),
					CPointDouble(pRohrKomponenteMI->GetThirdBorderpoint().X, pRohrKomponenteMI->GetThirdBorderpoint().Y), pRohrKomponenteMI->GetPitchCenterLinie());
				CPointDouble ullPunktConnectionPointAussenWand;
				ullPunktConnectionPointAussenWand.X = pRohrKomponenteMII->GetFirstBorderpoint().X + dFaktorZeroI * pRohrKomponenteMII->GetPitchCenterLinie().X;
				ullPunktConnectionPointAussenWand.Y = pRohrKomponenteMII->GetFirstBorderpoint().Y + dFaktorZeroI * pRohrKomponenteMII->GetPitchCenterLinie().Y;
				pRohrKomponenteMII->SetThirdCornerPoint(ullPunktConnectionPointAussenWand);
				pRohrKomponenteMI->SetFirstCornerPoint(ullPunktConnectionPointAussenWand);

				//Connection Point 1-2 Kompnente Zweite Aussenwand
				pRohrKomponenteMI->SetSecondBorderpoint(CumulatedArcCurrent);	
				pRohrKomponenteMI->SetFourthBorderpoint(CumulatedArcCurrent);
				dFaktorZeroI = CUtiltyHelper::GetFaktorForConnectionPoint( pRohrKomponenteMII->GetSecondBorderpoint(), pRohrKomponenteMII->GetPitchCenterLinie(),
					CPointDouble(pRohrKomponenteMI->GetForthBorderpoint().X, pRohrKomponenteMI->GetForthBorderpoint().Y), pRohrKomponenteMI->GetPitchCenterLinie());
				CPointDouble ullPunktConnectionPointAussenWandII;
				ullPunktConnectionPointAussenWandII.X = pRohrKomponenteMII->GetSecondBorderpoint().X + dFaktorZeroI * pRohrKomponenteMII->GetPitchCenterLinie().X;
				ullPunktConnectionPointAussenWandII.Y = pRohrKomponenteMII->GetSecondBorderpoint().Y + dFaktorZeroI * pRohrKomponenteMII->GetPitchCenterLinie().Y;
				pRohrKomponenteMII->SetForthCornerPoint(ullPunktConnectionPointAussenWandII);
				pRohrKomponenteMI->SetSecondCornerPoint(ullPunktConnectionPointAussenWandII);

			}

		
			//Zweite Kompnente
			//CumulatedArcCurrentII = CumulatedArcCurrentI;
			 pRohrKomponente->SetStartPointCenterLine( pRohrKomponenteMI->GetEndPointCenterLine());
			if(i < (int) ii-1)
			{
				 pRohrKomponente->SetGraficRohrKomponentenWinkel( pRohrKomponentePI );
			}
			else
			{ 
				break;
			}
			CumulatedArcCurrent +=  pRohrKomponente->SetEndPointCenterLine(CumulatedArcCurrent);
			 pRohrKomponente->SetFirstBorderpoint(CumulatedArcCurrent);	
			 pRohrKomponente->SetThirdBorderpoint(CumulatedArcCurrent);
			 pRohrKomponente->SetPitchForCenterLinie();
			if(i < (int) ii-1)
			{
				;
			}
			else
			{ 
				break;
			}

			//Connection Point 1-2 Kompnente erste Aussenwand
			double dFaktor = CUtiltyHelper::GetFaktorForConnectionPoint(  pRohrKomponenteMI->GetFirstBorderpoint(),  pRohrKomponenteMI->GetPitchCenterLinie(),
				CPointDouble( pRohrKomponente->GetThirdBorderpoint().X,  pRohrKomponente->GetThirdBorderpoint().Y),  pRohrKomponente->GetPitchCenterLinie());
			CPointDouble NullPunktConnectionPointAussenWand;
			NullPunktConnectionPointAussenWand.X =  pRohrKomponenteMI->GetFirstBorderpoint().X + dFaktor *  pRohrKomponenteMI->GetPitchCenterLinie().X;
			NullPunktConnectionPointAussenWand.Y =  pRohrKomponenteMI->GetFirstBorderpoint().Y + dFaktor *  pRohrKomponenteMI->GetPitchCenterLinie().Y;
			pRohrKomponenteMI->SetThirdCornerPoint(NullPunktConnectionPointAussenWand);
			pRohrKomponente->SetFirstCornerPoint(NullPunktConnectionPointAussenWand);

			//Connection Point 1-2 Kompnente Zweite Aussenwand
			pRohrKomponente->SetSecondBorderpoint(CumulatedArcCurrent);	
			pRohrKomponente->SetFourthBorderpoint(CumulatedArcCurrent);
			dFaktor = CUtiltyHelper::GetFaktorForConnectionPoint( pRohrKomponenteMI->GetSecondBorderpoint(), pRohrKomponenteMI->GetPitchCenterLinie(),
				CPointDouble(pRohrKomponente->GetForthBorderpoint().X, pRohrKomponente->GetForthBorderpoint().Y), pRohrKomponente->GetPitchCenterLinie());
			CPointDouble NullPunktConnectionPointAussenWandII;
			NullPunktConnectionPointAussenWandII.X = pRohrKomponenteMI->GetSecondBorderpoint().X + dFaktor * pRohrKomponenteMI->GetPitchCenterLinie().X;
			NullPunktConnectionPointAussenWandII.Y = pRohrKomponenteMI->GetSecondBorderpoint().Y + dFaktor * pRohrKomponenteMI->GetPitchCenterLinie().Y;
			pRohrKomponenteMI->SetForthCornerPoint(NullPunktConnectionPointAussenWandII);
			pRohrKomponente->SetSecondCornerPoint(NullPunktConnectionPointAussenWandII);



			//Dritte Kompnente
			pRohrKomponentePI->SetStartPointCenterLine(pRohrKomponente->GetEndPointCenterLine());
			if(i < (int) ii-2)
			{
				pRohrKomponentePI->SetGraficRohrKomponentenWinkel(pRohrKomponentePII);
			}
			else
			{ 
				break;
			}
		//	(*m_GraficStrangRohrKomponenten[i+1]).SetGraficRohrKomponentenWinkel(m_GraficStrangRohrKomponenten[i+1]);
			CumulatedArcCurrent += pRohrKomponentePI->SetEndPointCenterLine(CumulatedArcCurrent);
			pRohrKomponentePI->SetFirstBorderpoint(CumulatedArcCurrent);	
			pRohrKomponentePI->SetThirdBorderpoint(CumulatedArcCurrent);
			pRohrKomponentePI->SetPitchForCenterLinie();
			if(i < (int) ii-2)
			{
				;
			}
			else
			{ 
				break;
			}
			//Connection Point 2-3 Kompnente erste Aussenwand
			double dFaktor12 = CUtiltyHelper::GetFaktorForConnectionPoint( pRohrKomponente->GetFirstBorderpoint(), pRohrKomponente->GetPitchCenterLinie(),
				CPointDouble(pRohrKomponentePI->GetThirdBorderpoint().X, pRohrKomponentePI->GetThirdBorderpoint().Y), pRohrKomponentePI->GetPitchCenterLinie());
			NullPunktConnectionPointAussenWand.X = pRohrKomponente->GetFirstBorderpoint().X + dFaktor12 * pRohrKomponente->GetPitchCenterLinie().X;
			NullPunktConnectionPointAussenWand.Y = pRohrKomponente->GetFirstBorderpoint().Y + dFaktor12 * pRohrKomponente->GetPitchCenterLinie().Y;
			pRohrKomponente->SetThirdCornerPoint(NullPunktConnectionPointAussenWand);
			pRohrKomponentePI->SetFirstCornerPoint(NullPunktConnectionPointAussenWand);		
		
			//Connection Point 2-3 Kompnente Zweite Aussenwand
			pRohrKomponentePI->SetSecondBorderpoint(CumulatedArcCurrent);	
			pRohrKomponentePI->SetFourthBorderpoint(CumulatedArcCurrent);
			dFaktor = CUtiltyHelper::GetFaktorForConnectionPoint( pRohrKomponente->GetSecondBorderpoint(), pRohrKomponente->GetPitchCenterLinie(),
				CPointDouble(pRohrKomponentePI->GetForthBorderpoint().X, pRohrKomponentePI->GetForthBorderpoint().Y), pRohrKomponentePI->GetPitchCenterLinie());
			NullPunktConnectionPointAussenWandII.X = pRohrKomponente->GetSecondBorderpoint().X + dFaktor * pRohrKomponente->GetPitchCenterLinie().X;
			NullPunktConnectionPointAussenWandII.Y = pRohrKomponente->GetSecondBorderpoint().Y + dFaktor * pRohrKomponente->GetPitchCenterLinie().Y;
			pRohrKomponente->SetForthCornerPoint(NullPunktConnectionPointAussenWandII);
			pRohrKomponentePI->SetSecondCornerPoint(NullPunktConnectionPointAussenWandII);
			if( i+2 < (int)ii )
			{
				pRohrKomponentePII->SetStartPointCenterLine(pRohrKomponentePI->GetEndPointCenterLine());
			}

		}
	

		//EndElement
		CGraficRohrKomponente* pRohrKomponentePEnd = pGraficParentRohrOneAssembelVector->at(ii-1);
		CumulatedArcCurrent += pRohrKomponentePEnd->SetEndPointCenterLine(CumulatedArcCurrent);
		pRohrKomponentePEnd->SetFirstBorderpoint(CumulatedArcCurrent);
		pRohrKomponentePEnd->SetSecondBorderpoint(CumulatedArcCurrent);
		pRohrKomponentePEnd->SetPitchForCenterLinie();
	
				
		for(int i = 1; i < (int)ii; i++)
		{
			CGraficRohrKomponente* pRohrKomponente = pGraficParentRohrOneAssembelVector->at(i);
			pRohrKomponente->SetKomponentPointfromConectonPoint();
		}
	


		if(!bOnlyCaculateMainTube)
		{
			// Make Childs 
			if(pGraficParentRohrOneAssembelVector->HasAssembeldTubes())
			{
				CGraficRohrBemassungsKomponentenVectorVector& GraficParentRohrBemassungsKomponentenVectorVector = pGraficParentRohrOneAssembelVector->GetGraficBemassungsKomponentenVectorVector();
				std::vector<int>::size_type aa = GraficParentRohrBemassungsKomponentenVectorVector.size();
				for(int a = 0; a < (int)aa; a++)
				{
					CGraficRohrBemassungsRohrKomponentenVector* pGraficParentRohrBemassungsKomponentenVector = GraficParentRohrBemassungsKomponentenVectorVector[a];
		
					if(pGraficParentRohrBemassungsKomponentenVector->HasAssembeldTubes())
					{
				
						CGraficRohrKomponenteVectorVector& GraficContainerVectorVectorForAssembeldChildTubes = pGraficParentRohrBemassungsKomponentenVector->GetGraficRohrBemassungsAnbauChildKomponentenVectorVector();
						std::vector<int>::size_type bb = GraficContainerVectorVectorForAssembeldChildTubes.size();
						for(int b = 0; b < (int)bb; b++)
						{
	
							CCGraficRohrOneAssembeldKomponenteVector* pRohrOneAssembeldChildTubeVector = GraficContainerVectorVectorForAssembeldChildTubes[b];
							std::vector<int>::size_type cc = pRohrOneAssembeldChildTubeVector->size();
							//vorher int i = 1	
							for(int c = 0; c < (int)cc-1; c++)
							{
								CGraficRohrKomponente* pRohrChildKomponente  = pRohrOneAssembeldChildTubeVector->at(c);
								CGraficRohrKomponente* pRohrChildKomponenteI = pRohrOneAssembeldChildTubeVector->at(c+1);

								//CGraficRohrKomponente* pRohrKomponenteParent = pGraficParentRohrBemassungsKomponentenVector->at(1);

								double RelativerAbstandzumNaechsten = pRohrOneAssembeldChildTubeVector->GetRohrOneAssembeldKomponenteVector()->GetRelativerAbstandzumNaechsten();
								CPointDouble PointConnectionForAbgaenge = pGraficParentRohrBemassungsKomponentenVector->GetConnectionPointForAbgaenge(RelativerAbstandzumNaechsten); 
								
								pRohrChildKomponente->SetStartPointCenterLine(PointConnectionForAbgaenge);
								pRohrChildKomponente->SetGraficRohrKomponentenWinkel(NULL);
	
								double dCumulatedDummyWinkel = pGraficParentRohrBemassungsKomponentenVector->GetWinkelRohrZuXundYAchse() + 270;
								dCumulatedDummyWinkel += pRohrChildKomponente->SetEndPointCenterLine(dCumulatedDummyWinkel);
								pRohrChildKomponente->SetFirstBorderpoint(dCumulatedDummyWinkel);
								pRohrChildKomponente->SetSecondBorderpoint(dCumulatedDummyWinkel);
								pRohrChildKomponente->SetThirdBorderpoint(dCumulatedDummyWinkel);
								pRohrChildKomponente->SetFourthBorderpoint(dCumulatedDummyWinkel);
								pRohrChildKomponente->SetPitchForCenterLinie();
								pRohrChildKomponenteI->SetStartPointCenterLine( pRohrChildKomponente->GetEndPointCenterLine());
								pRohrChildKomponenteI->SetGraficRohrKomponentenWinkel(NULL);
								pRohrChildKomponente->SetKomponentPointfromConectonPoint();

								CreateGraficOneAssembeldTubeFromComponents(dCumulatedDummyWinkel, pRohrOneAssembeldChildTubeVector, bOnlyCaculateMainTube);
							}
				
						}
					}
				}
			}
		}
		
}






CGraficTubeController::~CGraficTubeController(void)
{
}
