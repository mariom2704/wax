#include "stdafx.h"
#include "StrangRohr.h"
#include "..\Grafic\Mechanicals Geometrics\GraficRohrKomponente.h"




 CRohrKomponente::CRohrKomponente(void)
{
	m_prevStrangRohr  = NULL;
	m_pNextStrangRohr = NULL;
	m_pGraficRohrKomponente = NULL;
	iDN			= 60;
	iLaenge		= 250;
	NutIdEnde	= 21;
	NutIdAnfang = 22;
	winkel		= 0;
}



 CGraficRohrKomponente* CRohrKomponenteTeilRohr::GetGraficRohrKomponente()
{
	if(m_pGraficRohrKomponente == 0)
	{
		m_pGraficRohrKomponente = new CGraficRohrKomponenteTeilRohr(this);
		return m_pGraficRohrKomponente;
	}
	else
	{
		return m_pGraficRohrKomponente;
	}
 };



CGraficRohrKomponente* CRohrKomponente::GetGraficRohrKomponente()
{
	if(m_pGraficRohrKomponente == 0)
	{
		m_pGraficRohrKomponente = new CGraficRohrKomponenteBogen(this);
		return m_pGraficRohrKomponente;
	}
	else
	{
		return m_pGraficRohrKomponente;
	}
 };



CRohrKomponente::~CRohrKomponente(void)
{
	if(m_pGraficRohrKomponente != 0)
	{
		delete m_pGraficRohrKomponente;
	}
}







CGraficRohrKomponente* CRohrKomponenteBogen::GetGraficRohrKomponente()
{
	if(m_pGraficRohrKomponente == 0)
	{
		CGraficRohrKomponenteBogen* pGraficRohrKomponente = new CGraficRohrKomponenteBogen(this);
		m_pGraficRohrKomponente = (CGraficRohrKomponente*) pGraficRohrKomponente;
		return m_pGraficRohrKomponente;
	}
	else
	{
		return m_pGraficRohrKomponente;
	}
 };

CGraficRohrKomponente* CRohrKomponenteNut::GetGraficRohrKomponente()
{
	if(m_pGraficRohrKomponente == 0)
	{
		CGraficRohrKomponenteNut* pGraficRohrKomponente = new CGraficRohrKomponenteNut(this);
		m_pGraficRohrKomponente = (CGraficRohrKomponente*) pGraficRohrKomponente;
		return m_pGraficRohrKomponente;
	}
	else
	{
		return m_pGraficRohrKomponente;
	}
 };

