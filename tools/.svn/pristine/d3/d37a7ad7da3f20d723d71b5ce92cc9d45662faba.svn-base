void CTestEingabe::OnBnClickedButton5()
{

	::AfxBeginThread(CTestEingabe::TestThread,this, THREAD_BASE_PRIORITY_MIN, 0, 0);	
	// TODO: Fügen Sie hier Ihren Kontrollbehandlungscode für die Benachrichtigung ein.
}



UINT CTestEingabe::TestThread(LPVOID pThis)
{
	while(true)
	{
		CTestEingabe* pTestEingabe = (CTestEingabe*) pThis;
		pTestEingabe->PostMessageA(WM_COMMAND, IDC_BUTTON1);
		Sleep(1000);
		//pTestEingabe->PostMessageA(WM_COMMAND, IDC_BUTTON2);
		//Sleep(1000);
		//pTestEingabe->PostMessageA(WM_COMMAND, IDC_BUTTON4);
		Sleep(1000);
	}
	return NULL;
}


